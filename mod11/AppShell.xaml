<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="mod11.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:mod11"
    xmlns:views="clr-namespace:mod11.Views"
    Title="mod11">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="PetListView"
        ContentTemplate="{DataTemplate views:PetListView}"
        Route="PetListView" />

</Shell>
