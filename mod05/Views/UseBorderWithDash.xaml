<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mod05.Views.UseBorderWithDash"
             Title="Lab06: 使用BorderWithDash">
    <VerticalStackLayout>
        <Border WidthRequest="380" Margin="10" Padding="15" 
            Stroke="blue" StrokeThickness="10"
            StrokeDashArray="5 3 1 2" StrokeDashOffset=".5" >
            <Label FontSize="48" FontFamily="ROR"  Text="Default"   />
        </Border>
        <Border WidthRequest="380"  Margin="10"  Padding="15" 
            Stroke="blue" StrokeThickness="10" StrokeLineJoin="Bevel"
            StrokeDashArray="5 3 1 2" StrokeDashOffset=".5" StrokeLineCap="Square" >
            <Label  FontSize="48" FontFamily="ROR"  Text="Square"   />
        </Border>
        <Border WidthRequest="380"  Margin="10"  Padding="15" 
            Stroke="blue" StrokeThickness="10" StrokeLineJoin="Round"
            StrokeDashArray="5 3 1 2" StrokeDashOffset=".5" StrokeLineCap="Round" >
            <Label  FontSize="48" FontFamily="ROR"  Text="Round"   />
        </Border>
       </VerticalStackLayout>
</ContentPage>