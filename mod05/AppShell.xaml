<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="mod05.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:mod05.Views"
    xmlns:local="clr-namespace:mod05"
    Shell.FlyoutBehavior="Disabled"
    Title="mod05">

    <TabBar>
        <ShellContent
             Title="Lab01: 字型"
             ContentTemplate="{DataTemplate local:MainPage}"
             Route="MainPage" />
        <ShellContent
             Title="Lab02: 使用BoxView 和 Image"
             ContentTemplate="{DataTemplate views:BoxViewAndImage}"
             Route="BoxViewAndImage" />
        <ShellContent
            Title="Lab03: 使用ScrollViewInGrid"
            ContentTemplate="{DataTemplate views:ScrollViewInGrid}"
            Route="ScrollViewInGrid" />
        <ShellContent
            Title="Lab04: 使用Border"
            ContentTemplate="{DataTemplate views:UseBorder}"
            Route="UseBorder" />
        <ShellContent
            Title="Lab05: 使用BorderWithLineJoin"
            ContentTemplate="{DataTemplate views:UseBorderWithLineJoin}"
            Route="UseBorderWithLineJoin" />
        <ShellContent
            Title="Lab06: 使用BorderWithDash"
            ContentTemplate="{DataTemplate views:UseBorderWithDash}"
            Route="UseBorderWithDash" />
        <ShellContent
            Title="Lab08: 使用GradientBrush"
            ContentTemplate="{DataTemplate views:UseGradientBrush}"
            Route="UseGradientBrush" />
        <ShellContent
            Title="SplashPage"
            ContentTemplate="{DataTemplate views:SplashPage}"
            Route="SplashPage" />
    </TabBar>

</Shell>
