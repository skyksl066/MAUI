<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mod04.Views.StackLayoutPage"
             Title="StackLayoutPage">
    
        <StackLayout x:Name="stack1" Spacing="5" Orientation="Horizontal">
            <Button x:Name="btnChangeLayout" Clicked="btnChangeLayout_Clicked" 
                Text="Change LayoutOption" BackgroundColor="Red" />
        <Label x:Name="lblOrange"   WidthRequest="100" HeightRequest="100"
               Text="Welcome to .NET MAUI!" BackgroundColor="Orange"/>
            <Label x:Name="lblYellow"   
               Text="Welcome to .NET MAUI!" BackgroundColor="Yellow" />
            <Label x:Name="lblGreen"  
               Text="Welcome to .NET MAUI!" BackgroundColor="Green" />
            <Label x:Name="lblBlue"
               Text="Welcome to .NET MAUI!" BackgroundColor="blue" />

            <Label Text="Indigo" BackgroundColor="#4B0082" TextColor="White" />
        <Label Text="Violet" BackgroundColor="#8A2BE2" TextColor="White" />
        <Label Text="Pink" BackgroundColor="#FFC0CB" TextColor="Black" />
        
    </StackLayout>
</ContentPage>