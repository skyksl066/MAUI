<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mod04.Views.VStackLayoutPage"
             Title="VStackLayoutPage">
    <VerticalStackLayout BackgroundColor="LightBlue" Margin="5" Padding="5">
        <Label Margin="5" Text="Welcome to .NET MAUI!" BackgroundColor="Red" />
        <Button Margin="5"  x:Name="btnChangeMargin"  Clicked="btnChangeMargin_Click"  Text="Welcome to .NET MAUI!" BackgroundColor="Orange"/>
        <Button Margin="5"  x:Name="btnChangePadding" Clicked="btnChangePadding_Clicked"    Text="Welcome to .NET MAUI!" BackgroundColor="Yellow" />
        <Label Margin="5"   Text="Welcome to .NET MAUI!" BackgroundColor="Green" />
        <Label Margin="5"   Text="Welcome to .NET MAUI!" BackgroundColor="blue" />
        <Label Margin="15,10,50,0"   Text="Welcome to .NET MAUI!" BackgroundColor="Indigo" />
        <Label Margin="5"   Text="Welcome to .NET MAUI!" BackgroundColor="Purple" />
    </VerticalStackLayout>
</ContentPage>