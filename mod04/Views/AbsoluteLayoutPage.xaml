<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mod04.Views.AbsoluteLayoutPage"
             Title="Lab07: AbsoluteLayoutPage">
    <VerticalStackLayout>
        <AbsoluteLayout>
            <Label  AbsoluteLayout.LayoutBounds="50,10,400,200"
            Text="Welcome to .NET MAUI!" FontSize="20" BackgroundColor="Orange"/>
            <Label  AbsoluteLayout.LayoutBounds=".5,.5,.5,.5"
                AbsoluteLayout.LayoutFlags="SizeProportional,PositionProportional"
            Text="Welcome to .NET MAUI!"  FontSize="20" BackgroundColor="Yellow"/>
        </AbsoluteLayout>

    </VerticalStackLayout>
</ContentPage>