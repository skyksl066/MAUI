<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="mod04.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:mod04"
    xmlns:views="clr-namespace:mod04.Views"
    FlyoutBehavior="Flyout"
    Title="mod04">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="HStackLayout"
        ContentTemplate="{DataTemplate views:HStackLayoutPage}"
        Route="HStackLayoutPage" />
    <ShellContent
        Title="StackLayout"
        ContentTemplate="{DataTemplate views:StackLayoutPage}"
        Route="StackLayoutPage" />
    <ShellContent
        Title="VStackLayout"
        ContentTemplate="{DataTemplate views:VStackLayoutPage}"
        Route="VStackLayoutPage" />
    <ShellContent
        Title="GridPage"
        ContentTemplate="{DataTemplate views:GridPage}"
        Route="GridPage" />
    <ShellContent
        Title="FlexLayoutPage"
        ContentTemplate="{DataTemplate views:FlexLayoutPage}"
        Route="FlexLayoutPage" />
    <ShellContent
        Title="AbsoluteLayoutPage"
        ContentTemplate="{DataTemplate views:AbsoluteLayoutPage}"
        Route="AbsoluteLayoutPage" />

</Shell>
