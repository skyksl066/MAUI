<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="mod09.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:mod09"
    xmlns:views="clr-namespace:mod09.Views"
    Title="mod09">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="TimeView"
        ContentTemplate="{DataTemplate views:TimeView}"
        Route="TimeView" />
    <ShellContent
        Title="PetListView"
        ContentTemplate="{DataTemplate views:PetListView}"
        Route="PetListView" />
    
</Shell>
