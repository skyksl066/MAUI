<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="mod06.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:mod06"
    xmlns:views="clr-namespace:mod06.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="mod06">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="UseLabel"
        ContentTemplate="{DataTemplate views:UseLabel}"
        Route="UseLabel" />
    <ShellContent
        Title="UseButton"
        ContentTemplate="{DataTemplate views:UseButton}"
        Route="UseButton" />
    <ShellContent
        Title="UseEditor"
        ContentTemplate="{DataTemplate views:UseEditor}"
        Route="UseEditor" />
    <ShellContent
        Title="UseOtherEntry"
        ContentTemplate="{DataTemplate views:UseOtherEntry}"
        Route="UseOtherEntry" />
    <ShellContent
        Title="UseDateTimePicker"
        ContentTemplate="{DataTemplate views:UseDateTimePicker}"
        Route="UseDateTimePicker" />
    <ShellContent
        Title="UseActivity"
        ContentTemplate="{DataTemplate views:UseActivity}"
        Route="UseActivity" />
    
</Shell>
