<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="mod06.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:mod06"
    xmlns:views="clr-namespace:mod06.Views"
    Shell.FlyoutBehavior="Flyout"
    Title="mod06">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="Lab01: 使用 Label"
        ContentTemplate="{DataTemplate views:UseLabel}"
        Route="UseLabel" />
    <ShellContent
        Title="Lab02: 使用按鈕"
        ContentTemplate="{DataTemplate views:UseButton}"
        Route="UseButton" />
    <ShellContent
        Title="Lab03: 使用文字編輯控制項"
        ContentTemplate="{DataTemplate views:UseEditor}"
        Route="UseEditor" />
    <ShellContent
        Title="Lab04: 更多設定值控制"
        ContentTemplate="{DataTemplate views:UseOtherEntry}"
        Route="UseOtherEntry" />
    <ShellContent
        Title="Lab05: 日期/時間 選擇器"
        ContentTemplate="{DataTemplate views:UseDateTimePicker}"
        Route="UseDateTimePicker" />
    <ShellContent
        Title="Lab06: 表示活動進行中的控制項"
        ContentTemplate="{DataTemplate views:UseActivity}"
        Route="UseActivity" />
    
</Shell>
